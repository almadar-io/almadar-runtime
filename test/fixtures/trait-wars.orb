      "traits": [
        {
          "name": "WorldExploration",
          "category": "interaction",
          "linkedEntity": "MapHex",
          "listens": [
            { "event": "TURN_CHANGED", "from": "SessionManager" }
          ],
          "stateMachine": {
            "states": [
              { "name": "exploring", "isInitial": true },
              { "name": "heroSelected" },
              { "name": "heroMoving" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "SELECT_HERO", "name": "Select Hero" },
              { "key": "MOVE_HERO", "name": "Move Hero" },
              { "key": "COLLECT_RESOURCE", "name": "Collect Resource" },
              { "key": "ENTER_CASTLE", "name": "Enter Castle", "payload": [{ "name": "castleId", "type": "string", "required": true }] },
              { "key": "BATTLE_ENCOUNTER", "name": "Battle Encounter", "payload": [{ "name": "enemyId", "type": "string", "required": true }] },
              { "key": "END_TURN", "name": "End Turn" },
              { "key": "BACK", "name": "Deselect" },
              { "key": "TURN_CHANGED", "name": "Turn Changed", "payload": [{ "name": "activePlayerId", "type": "string", "required": true }, { "name": "turn", "type": "number", "required": true }] }
            ],
            "transitions": [
              {
                "from": "exploring",
                "to": "exploring",
                "event": "INIT",
                "effects": [
                  ["fetch", "MapHex"],
                  ["render-ui", "main", {
                    "type": "game-isometric-canvas",
                    "entity": "@entity",
                    "scale": 0.4,
                    "onTileClick": "SELECT_HERO"
                  }],
                  ["render-ui", "hud-top", {
                    "type": "game-resource-bar",
                    "resources": ["gold", "resonance", "salvage", "traitShards"],
                    "compact": false
                  }]
                ]
              },
              {
                "from": "exploring",
                "to": "heroSelected",
                "event": "SELECT_HERO"
              },
              {
                "from": "heroSelected",
                "to": "heroMoving",
                "event": "MOVE_HERO"
              },
              {
                "from": "heroMoving",
                "to": "exploring",
                "event": "COLLECT_RESOURCE",
                "effects": [
                  ["persist", "update", "MapHex", "@entity"]
                ]
              },
              {
                "from": "heroMoving",
                "to": "exploring",
                "event": "BATTLE_ENCOUNTER",
                "effects": [
                  ["navigate", "/battle", { "enemyId": "@payload.enemyId" }]
                ]
              },
              {
                "from": "heroMoving",
                "to": "exploring",
                "event": "ENTER_CASTLE",
                "effects": [
                  ["navigate", "/castle", { "id": "@payload.castleId" }]
                ]
              },
              {
                "from": "heroSelected",
                "to": "exploring",
                "event": "BACK"
              },
              {
                "from": "exploring",
                "to": "exploring",
                "event": "END_TURN"
              },
              {
                "from": "exploring",
                "to": "exploring",
                "event": "TURN_CHANGED",
                "effects": [
                  ["fetch", "MapHex"]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "WorldMapPage",
          "path": "/world",
          "viewType": "list",
          "primaryEntity": "MapHex",
          "traits": [{ "ref": "WorldExploration" }]
