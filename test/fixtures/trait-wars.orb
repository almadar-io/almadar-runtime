    {
      "name": "HeroManagement",
      "description": "Hero profiles with stats, trait slot management, and level progression using composed atom/molecule patterns",
      "visual_prompt": "Scene: Hero selection screen. Style: 'Illuminated Manuscript Futurism'. Layout: Ornate gold-framed portraits with trait icons. Atmosphere: Legendary commanders.",
      "entity": {
        "name": "Hero",
        "persistence": "persistent",
        "collection": "heroes",
        "fields": [
          { "name": "id", "type": "string", "required": true, "primaryKey": true },
          { "name": "name", "type": "string", "required": true },
          { "name": "archetype", "type": "enum", "values": ["innocent", "orphan", "caregiver", "hero", "explorer", "rebel", "lover", "creator", "jester", "sage", "magician", "ruler"], "required": true },
          { "name": "level", "type": "number", "required": true },
          { "name": "xp", "type": "number", "default": 0 },
          { "name": "xpToNextLevel", "type": "number", "default": 100 },
          { "name": "health", "type": "number", "required": true },
          { "name": "maxHealth", "type": "number", "required": true },
          { "name": "attack", "type": "number", "required": true },
          { "name": "defense", "type": "number", "required": true },
          { "name": "speed", "type": "number", "default": 3 },
          { "name": "leadership", "type": "number", "default": 1 },
          { "name": "traitSlots", "type": "number", "default": 3 },
          { "name": "portraitUrl", "type": "string" },
          { "name": "biography", "type": "string" },
          { "name": "ownerId", "type": "string" },
          { "name": "sessionId", "type": "string" }
        ],
        "instances": [
          { "id": "hero-valor", "name": "Commander Valor", "archetype": "hero", "level": 3, "xp": 45, "xpToNextLevel": 150, "health": 120, "maxHealth": 120, "attack": 20, "defense": 15, "speed": 4, "leadership": 3, "traitSlots": 3, "biography": "A seasoned warrior who leads by example. His shield has deflected a thousand blows." },
          { "id": "hero-lumis", "name": "Lumis the Wise", "archetype": "sage", "level": 4, "xp": 80, "xpToNextLevel": 200, "health": 75, "maxHealth": 75, "attack": 28, "defense": 8, "speed": 2, "leadership": 2, "traitSlots": 4, "biography": "An ancient spellweaver whose knowledge of the arcane arts is matched only by their patience." },
          { "id": "hero-scrap", "name": "Scrap the Survivor", "archetype": "orphan", "level": 2, "xp": 20, "xpToNextLevel": 100, "health": 90, "maxHealth": 90, "attack": 14, "defense": 18, "speed": 3, "leadership": 1, "traitSlots": 3, "biography": "Found in the wreckage of a forgotten battlefield, Scrap endures where others fall." }
        ]
      },
      "traits": [
        {
          "name": "HeroBrowser",
          "category": "interaction",
          "linkedEntity": "Hero",
          "emits": [
            { "event": "HERO_SELECTED", "scope": "external", "payload": [{ "name": "heroId", "type": "string", "required": true }] }
          ],
          "stateMachine": {
            "states": [
              { "name": "browsing", "isInitial": true },
              { "name": "viewing" },
              { "name": "equipping" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "SELECT", "name": "Select Hero", "payload": [{ "name": "heroId", "type": "string", "required": true }] },
              { "key": "EQUIP_TRAIT", "name": "Equip Trait" },
              { "key": "REMOVE_TRAIT", "name": "Remove Trait" },
              { "key": "LEVEL_UP", "name": "Level Up" },
              { "key": "JOIN_BATTLE", "name": "Join Battle", "payload": [{ "name": "heroId", "type": "string", "required": true }] },
              { "key": "BACK", "name": "Back to List" }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  ["fetch", "Hero", { "ownerId": "@user.id" }],
                  ["render-ui", "main", {
                    "type": "entity-cards",
                    "entity": "Hero",
                    "columns": 4,
                    "itemActions": [
                      { "label": "Select", "event": "SELECT" },
                      { "label": "Deploy", "event": "JOIN_BATTLE" }
                    ]
                  }]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing",
                "event": "SELECT",
                "effects": [
                  ["emit", "HERO_SELECTED", { "heroId": "@payload.heroId" }],
                  ["render-ui", "main", {
                    "type": "game-hero-profile",
                    "hero": "@payload.heroId",
                    "onEquipTrait": "EQUIP_TRAIT",
                    "onRemoveTrait": "REMOVE_TRAIT"
                  }],
                  ["render-ui", "sidebar", {
                    "type": "game-trait-slot",
                    "slotIndex": 0,
                    "trait": "@entity.traitState",
                    "onEquip": "EQUIP_TRAIT",
                    "onRemove": "REMOVE_TRAIT"
                  }],
                  ["render-ui", "hud-top", {
                    "type": "game-resource-bar",
                    "resources": ["health", "attack", "defense", "speed", "leadership"],
                    "compact": true
                  }]
                ]
              },
              {
                "from": "viewing",
                "to": "equipping",
                "event": "EQUIP_TRAIT"
              },
              {
                "from": "equipping",
                "to": "viewing",
                "event": "EQUIP_TRAIT"
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "REMOVE_TRAIT"
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "LEVEL_UP",
                "guard": [">=", "@entity.xp", "@entity.xpToNextLevel"],
                "effects": [
                  ["set", "@entity.level", ["+", "@entity.level", 1]],
                  ["set", "@entity.xp", ["-", "@entity.xp", "@entity.xpToNextLevel"]],
                  ["persist", "update", "Hero", "@entity"]
                ]
              },
              {
                "from": "viewing",
                "to": "browsing",
                "event": "JOIN_BATTLE",
                "effects": [
                  ["navigate", "/battle", { "heroId": "@payload.heroId" }]
                ]
              },
              { "from": "viewing", "to": "browsing", "event": "BACK" }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "HeroListPage",
          "path": "/heroes",
          "viewType": "list",
          "primaryEntity": "Hero",
          "traits": [{ "ref": "HeroBrowser" }]
        },
        {
          "name": "HeroDetailPage",
          "path": "/hero/:id",
          "viewType": "detail",
          "primaryEntity": "Hero",
          "traits": [{ "ref": "HeroBrowser" }]
        }
      ],
      "domainContext": {
        "category": "game",
        "vocabulary": {
          "item": "Hero",
          "create": "Recruit Hero",
          "view": "Inspect Hero"
        },
        "requestFragment": "Hero profiles with avatar display, trait slot management, stat bars, and level progression"
      }
    },
    {
      "name": "Economy",
      "description": "Player resource management — gold, resonance, salvage, and trait caches",
      "visual_prompt": "Scene: Resource treasury overview. Style: 'Illuminated Manuscript Futurism'. Layout: Resource counters with income/expense tracking. Atmosphere: Strategic resource planning.",
      "entity": {
        "name": "PlayerResources",
        "persistence": "persistent",
        "collection": "playerResources",
        "fields": [
          { "name": "id", "type": "string", "required": true, "primaryKey": true },
          { "name": "gold", "type": "number", "required": true, "default": 500 },
          { "name": "resonance", "type": "number", "required": true, "default": 50 },
          { "name": "salvage", "type": "number", "required": true, "default": 0 },
          { "name": "traitShards", "type": "number", "required": true, "default": 0 },
          { "name": "incomePerTurn", "type": "number", "default": 100 },
          { "name": "ownerId", "type": "string" },
          { "name": "sessionId", "type": "string" }
        ],
        "instances": [
          { "id": "player-resources-default", "gold": 500, "resonance": 50, "salvage": 0, "traitShards": 0, "incomePerTurn": 100 }
        ]
      },
      "traits": [
        {
          "name": "ResourceManager",
          "category": "interaction",
          "linkedEntity": "PlayerResources",
          "listens": [
            { "event": "SPEND_GOLD", "from": "CastleManagement" }
          ],
          "stateMachine": {
            "states": [
              { "name": "active", "isInitial": true }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "GAIN_RESOURCE", "name": "Gain Resource", "payload": [
                { "name": "resourceType", "type": "string", "required": true },
                { "name": "amount", "type": "number", "required": true }
              ]},
              { "key": "SPEND_RESOURCE", "name": "Spend Resource", "payload": [
                { "name": "resourceType", "type": "string", "required": true },
                { "name": "amount", "type": "number", "required": true }
              ]},
              { "key": "GAIN_BATTLE_REWARD", "name": "Gain Battle Reward", "payload": [
                { "name": "gold", "type": "number" },
                { "name": "resonance", "type": "number" },
                { "name": "salvage", "type": "number" },
                { "name": "traitShards", "type": "number" }
              ]},
              { "key": "SPEND_GOLD", "name": "Spend Gold", "payload": [
                { "name": "amount", "type": "number", "required": true },
                { "name": "reason", "type": "string", "required": true }
              ]}
            ],
            "transitions": [
              {
                "from": "active",
                "to": "active",
                "event": "INIT",
                "effects": [
                  ["fetch", "PlayerResources", { "ownerId": "@user.id" }],
                  ["render-ui", "hud-top", {
                    "type": "game-resource-bar",
                    "resources": ["gold", "resonance", "salvage", "traitShards"],
                    "compact": true
                  }]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "GAIN_RESOURCE",
                "effects": [
                  ["set", "@entity.gold", ["+", "@entity.gold", "@payload.amount"]],
                  ["persist", "update", "PlayerResources", "@entity"]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "SPEND_RESOURCE",
                "guard": [">=", "@entity.gold", "@payload.amount"],
                "effects": [
                  ["set", "@entity.gold", ["-", "@entity.gold", "@payload.amount"]],
                  ["persist", "update", "PlayerResources", "@entity"]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "SPEND_GOLD",
                "guard": [">=", "@entity.gold", "@payload.amount"],
                "effects": [
                  ["set", "@entity.gold", ["-", "@entity.gold", "@payload.amount"]],
                  ["persist", "update", "PlayerResources", "@entity"]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "GAIN_BATTLE_REWARD",
                "effects": [
                  ["set", "@entity.gold", ["+", "@entity.gold", "@payload.gold"]],
                  ["set", "@entity.resonance", ["+", "@entity.resonance", "@payload.resonance"]],
                  ["set", "@entity.salvage", ["+", "@entity.salvage", "@payload.salvage"]],
                  ["set", "@entity.traitShards", ["+", "@entity.traitShards", "@payload.traitShards"]],
                  ["persist", "update", "PlayerResources", "@entity"]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "ResourcesPage",
          "path": "/resources",
          "viewType": "detail",
          "primaryEntity": "PlayerResources",
          "traits": [{ "ref": "ResourceManager" }]
        }
      ],
      "domainContext": {
        "category": "game",
        "vocabulary": {
          "item": "Resource",
          "view": "View Treasury"
        },
        "requestFragment": "Resource management with income tracking, expenditure guards, and battle rewards",
        "notes": "AI opponent logic is implemented externally via the runtime's effect executor and is NOT modeled as an orbital trait — enemy turn resolution, targeting, and difficulty scaling live in the game client code."
      }
    },
    {
      "name": "Lobby",
      "description": "Multiplayer session management — matchmaking, mode selection (PvP / Co-op), and turn coordination across all orbitals",
      "entity": {
        "name": "GameSession",
        "persistence": "persistent",
        "collection": "gameSessions",
        "fields": [
          { "name": "id", "type": "string", "required": true, "primaryKey": true },
          { "name": "player1Id", "type": "string", "required": true },
          { "name": "player2Id", "type": "string" },
          { "name": "status", "type": "enum", "values": ["waiting", "ready", "inProgress", "completed"], "required": true },
          { "name": "mode", "type": "enum", "values": ["pvp", "coop"], "required": true },
          { "name": "currentTurn", "type": "number", "default": 1 },
          { "name": "activePlayerId", "type": "string" },
          { "name": "winnerId", "type": "string" },
          { "name": "createdAt", "type": "number" }
        ],
        "instances": []
      },
      "traits": [
        {
          "name": "SessionManager",
          "category": "interaction",
          "linkedEntity": "GameSession",
          "emits": [
            { "event": "TURN_CHANGED", "scope": "external", "payload": [{ "name": "activePlayerId", "type": "string", "required": true }, { "name": "turn", "type": "number", "required": true }] }
          ],
          "stateMachine": {
            "states": [
              { "name": "idle", "isInitial": true },
              { "name": "waiting" },
              { "name": "inProgress" },
              { "name": "completed", "isTerminal": true }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "CREATE_SESSION", "name": "Create Session", "payload": [
                { "name": "mode", "type": "string", "required": true }
              ]},
              { "key": "JOIN_SESSION", "name": "Join Session", "payload": [
                { "name": "sessionId", "type": "string", "required": true }
              ]},
              { "key": "START_GAME", "name": "Start Game" },
              { "key": "END_TURN", "name": "End Turn" },
              { "key": "END_GAME", "name": "End Game", "payload": [
                { "name": "winnerId", "type": "string", "required": true }
              ]}
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  ["fetch", "GameSession"],
                  ["render-ui", "main", {
                    "type": "entity-cards",
                    "entity": "GameSession",
                    "columns": 2,
                    "itemActions": [
                      { "label": "Join", "event": "JOIN_SESSION" }
                    ]
                  }]
                ]
              },
              {
                "from": "idle",
                "to": "waiting",
                "event": "CREATE_SESSION",
                "effects": [
                  ["persist", "create", "GameSession", {
                    "player1Id": "@user.id",
                    "status": "waiting",
                    "mode": "@payload.mode",
                    "currentTurn": 1,
                    "activePlayerId": "@user.id"
                  }],
                  ["render-ui", "main", {
                    "type": "entity-cards",
                    "entity": "GameSession",
                    "columns": 1,
                    "itemActions": [
                      { "label": "Start", "event": "START_GAME" }
                    ]
                  }]
                ]
              },
              {
                "from": "waiting",
                "to": "inProgress",
                "event": "JOIN_SESSION",
                "effects": [
                  ["set", "@entity.player2Id", "@user.id"],
                  ["set", "@entity.status", "ready"],
                  ["persist", "update", "GameSession", "@entity"]
                ]
              },
              {
                "from": "inProgress",
                "to": "inProgress",
                "event": "START_GAME",
                "guard": ["==", "@entity.status", "ready"],
                "effects": [
                  ["set", "@entity.status", "inProgress"],
                  ["persist", "update", "GameSession", "@entity"],
                  ["navigate", "/world"]
                ]
              },
              {
                "from": "inProgress",
                "to": "inProgress",
                "event": "END_TURN",
                "guard": ["==", "@entity.activePlayerId", "@user.id"],
                "effects": [
                  ["set", "@entity.currentTurn", ["+", "@entity.currentTurn", 1]],
                  ["set", "@entity.activePlayerId", ["if", ["==", "@entity.activePlayerId", "@entity.player1Id"], "@entity.player2Id", "@entity.player1Id"]],
                  ["persist", "update", "GameSession", "@entity"],
                  ["emit", "TURN_CHANGED", { "activePlayerId": "@entity.activePlayerId", "turn": "@entity.currentTurn" }]
                ]
              },
              {
                "from": "inProgress",
                "to": "completed",
                "event": "END_GAME",
                "effects": [
                  ["set", "@entity.status", "completed"],
                  ["set", "@entity.winnerId", "@payload.winnerId"],
                  ["persist", "update", "GameSession", "@entity"],
                  ["render-ui", "main", {
                    "type": "entity-cards",
                    "entity": "GameSession",
                    "columns": 1,
                    "itemActions": [
                      { "label": "Return to Lobby", "event": "INIT" }
                    ]
                  }]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "LobbyPage",
          "path": "/lobby",
          "viewType": "list",
          "primaryEntity": "GameSession",
          "traits": [{ "ref": "SessionManager" }]
        }
      ],
      "domainContext": {
        "category": "game",
        "vocabulary": {
          "item": "Session",
          "create": "Create Game",
          "view": "View Lobby"
        },
        "requestFragment": "Multiplayer lobby with session creation, matchmaking, and turn coordination for PvP and Co-op modes",
        "notes": "Realtime sync between players (WebSocket/Firebase Realtime) is implemented externally via the runtime. The .orb schema defines the session state machine and turn logic; the runtime handles real-time event propagation. PvP perspective-based team mapping and ally unit styling (green borders for player 2) are also handled in the canvas renderer, not in the schema."
      }
    }
  ]
}
