{
  "name": "TraitWars",
  "version": "3.0.0",
  "description": "Trait Wars - Canvas-based tactical strategy using composed game patterns",
  "_metadata": {
    "version": 2,
    "createdAt": 1738666800000,
    "updatedAt": 1738886929000,
    "source": "manual"
  },
  "orbitals": [
    {
      "name": "TacticalBattle",
      "description": "Isometric tactical battle with phase-based turns, canvas rendering, and combat UI overlays",
      "visual_prompt": "Scene: Isometric tactical battlefield. Style: 'Illuminated Manuscript Futurism'. Terrain: Ancient parchment-colored tiles with gold geometric borders. Atmosphere: Strategic warfare on sacred ground.",
      "theme": {
        "name": "trait-wars-dark",
        "tokens": {
          "colors": {
            "primary": "#ef4444",
            "accent": "#f97316",
            "background": "#0f172a",
            "foreground": "#f8fafc",
            "surface": "#1e293b",
            "muted": "#64748b"
          },
          "typography": {
            "font-family": "'Press Start 2P', monospace"
          }
        }
      },
      "entity": {
        "name": "Unit",
        "persistence": "runtime",
        "collection": "units",
        "fields": [
          { "name": "id", "type": "string", "required": true, "primaryKey": true },
          { "name": "name", "type": "string", "required": true },
          { "name": "characterType", "type": "enum", "values": ["knight", "mage", "assassin", "archer", "healer", "boss", "innocent", "orphan", "caregiver", "hero", "explorer", "rebel", "lover", "creator", "jester", "sage", "magician", "ruler"], "required": true },
          { "name": "team", "type": "enum", "values": ["player", "enemy", "ally", "neutral"], "required": true },
          { "name": "health", "type": "number", "required": true },
          { "name": "maxHealth", "type": "number", "required": true },
          { "name": "attack", "type": "number", "required": true },
          { "name": "defense", "type": "number", "required": true },
          { "name": "movement", "type": "number", "required": true },
          { "name": "positionX", "type": "number", "required": true },
          { "name": "positionY", "type": "number", "required": true },
          { "name": "traitState", "type": "string" },
          { "name": "mana", "type": "number" },
          { "name": "turnsEnraged", "type": "number", "default": 0 },
          { "name": "damageBonus", "type": "number", "default": 1 },
          { "name": "shieldIntegrity", "type": "number", "default": 100 },
          { "name": "recoveryTurns", "type": "number", "default": 0 },
          { "name": "restTurns", "type": "number", "default": 0 },
          { "name": "shieldTarget", "type": "string" },
          { "name": "deployedHeroId", "type": "string" },
          { "name": "sessionId", "type": "string" }
        ],
        "instances": [
          { "id": "player-knight", "name": "Sir Roland", "characterType": "hero", "team": "player", "health": 100, "maxHealth": 100, "attack": 18, "defense": 12, "movement": 2, "positionX": 1, "positionY": 2, "traitState": "calm" },
          { "id": "player-mage", "name": "Archmage Lyra", "characterType": "magician", "team": "player", "health": 65, "maxHealth": 65, "attack": 22, "defense": 5, "movement": 1, "positionX": 1, "positionY": 4, "traitState": "channeling", "mana": 80 },
          { "id": "player-healer", "name": "Sister Vael", "characterType": "caregiver", "team": "player", "health": 55, "maxHealth": 55, "attack": 8, "defense": 8, "movement": 2, "positionX": 0, "positionY": 3, "traitState": "idle" },
          { "id": "enemy-warrior", "name": "Dark Knight", "characterType": "knight", "team": "enemy", "health": 90, "maxHealth": 90, "attack": 16, "defense": 14, "movement": 2, "positionX": 7, "positionY": 2, "traitState": "idle" },
          { "id": "enemy-mage", "name": "Shadow Mage", "characterType": "mage", "team": "enemy", "health": 55, "maxHealth": 55, "attack": 24, "defense": 4, "movement": 1, "positionX": 7, "positionY": 4, "traitState": "channeling", "mana": 60 },
          { "id": "enemy-assassin", "name": "Venom Blade", "characterType": "assassin", "team": "enemy", "health": 50, "maxHealth": 50, "attack": 20, "defense": 6, "movement": 3, "positionX": 6, "positionY": 3, "traitState": "idle" }
        ]
      },
      "traits": [
        {
          "name": "BattlePhaseController",
          "category": "interaction",
          "linkedEntity": "Unit",
          "listens": [
            { "event": "HERO_SELECTED", "from": "HeroBrowser" },
            { "event": "SHIELD_BREAK", "from": "GuardianBehavior" }
          ],
          "stateMachine": {
            "states": [
              { "name": "observation", "isInitial": true },
              { "name": "selection" },
              { "name": "movement" },
              { "name": "action" },
              { "name": "enemyTurn" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "SELECT_UNIT", "name": "Select Unit", "payload": [{ "name": "unitId", "type": "string", "required": true }] },
              { "key": "MOVE", "name": "Move Unit" },
              { "key": "ATTACK", "name": "Attack", "payload": [{ "name": "damage", "type": "number", "required": true }, { "name": "targetX", "type": "number", "required": true }, { "name": "targetY", "type": "number", "required": true }] },
              { "key": "END_TURN", "name": "End Turn" },
              { "key": "ENEMY_COMPLETE", "name": "Enemy Complete" },
              { "key": "BATTLE_END", "name": "Battle End" },
              { "key": "BATTLE_WON", "name": "Battle Won" },
              { "key": "DEPLOY_HERO", "name": "Deploy Hero", "payload": [{ "name": "heroId", "type": "string", "required": true }, { "name": "name", "type": "string", "required": true }, { "name": "characterType", "type": "string", "required": true }, { "name": "attack", "type": "number", "required": true }, { "name": "defense", "type": "number", "required": true }, { "name": "health", "type": "number", "required": true }] },
              { "key": "HERO_SELECTED", "name": "Hero Selected", "payload": [{ "name": "heroId", "type": "string", "required": true }] },
              { "key": "SHIELD_BREAK", "name": "Shield Break", "payload": [{ "name": "unitId", "type": "string", "required": true }] }
            ],
            "transitions": [
              {
                "from": "observation",
                "to": "observation",
                "event": "INIT",
                "effects": [
                  ["fetch", "Unit"],
                  ["render-ui", "main", {
                    "type": "game-isometric-canvas",
                    "entity": "@entity",
                    "scale": 0.6,
                    "onTileClick": "SELECT_UNIT"
                  }],
                  ["render-ui", "sidebar", {
                    "type": "game-combat-log",
                    "events": [],
                    "maxVisible": 50
                  }],
                  ["render-ui", "hud-bottom", {
                    "type": "game-trait-viewer",
                    "trait": "@entity.traitState",
                    "showTransitions": true
                  }]
                ]
              },
              {
                "from": "observation",
                "to": "selection",
                "event": "SELECT_UNIT",
                "effects": [
                  ["render-ui", "hud-bottom", {
                    "type": "game-trait-viewer",
                    "trait": "@entity.traitState",
                    "showTransitions": true
                  }]
                ]
              },
              {
                "from": "selection",
                "to": "movement",
                "event": "SELECT_UNIT"
              },
              {
                "from": "movement",
                "to": "action",
                "event": "MOVE",
                "effects": [
                  ["persist", "update", "Unit", "@payload"]
                ]
              },
              {
                "from": "action",
                "to": "observation",
                "event": "ATTACK",
                "effects": [
                  ["persist", "update", "Unit", "@payload"],
                  ["render-ui", "overlay", {
                    "type": "game-damage-popup",
                    "amount": "@payload.damage",
                    "damageType": "physical",
                    "x": "@payload.targetX",
                    "y": "@payload.targetY"
                  }]
                ]
              },
              { "from": "action", "to": "observation", "event": "END_TURN" },
              { "from": "observation", "to": "enemyTurn", "event": "END_TURN" },
              { "from": "enemyTurn", "to": "observation", "event": "ENEMY_COMPLETE" },
              {
                "from": "observation",
                "to": "observation",
                "event": "HERO_SELECTED",
                "effects": [
                  ["set", "@entity.deployedHeroId", "@payload.heroId"]
                ]
              },
              {
                "from": "observation",
                "to": "observation",
                "event": "SHIELD_BREAK",
                "effects": [
                  ["fetch", "Unit"]
                ]
              },
              {
                "from": "observation",
                "to": "observation",
                "event": "BATTLE_END",
                "effects": [
                  ["persist", "update", "Unit", "@payload"],
                  ["navigate", "/world"]
                ]
              },
              {
                "from": "observation",
                "to": "observation",
                "event": "BATTLE_WON",
                "effects": [
                  ["persist", "update", "Unit", "@payload"],
                  ["navigate", "/world"]
                ]
              },
              {
                "from": "observation",
                "to": "observation",
                "event": "DEPLOY_HERO",
                "effects": [
                  ["persist", "create", "Unit", {
                    "id": "@payload.heroId",
                    "name": "@payload.name",
                    "characterType": "@payload.characterType",
                    "team": "player",
                    "health": "@payload.health",
                    "maxHealth": "@payload.health",
                    "attack": "@payload.attack",
                    "defense": "@payload.defense",
                    "movement": 2,
                    "positionX": 0,
                    "positionY": 0,
                    "deployedHeroId": "@payload.heroId"
                  }]
                ]
              }
            ]
          }
        },
        {
          "name": "BerserkerBehavior",
          "category": "lifecycle",
          "linkedEntity": "Unit",
          "stateMachine": {
            "states": [
              { "name": "calm", "isInitial": true },
              { "name": "enraged" },
              { "name": "exhausted" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "TAKE_DAMAGE", "name": "Take Damage", "payload": [{ "name": "amount", "type": "number", "required": true }] },
              { "key": "ATTACK", "name": "Attack" },
              { "key": "REST", "name": "Rest" },
              { "key": "TICK", "name": "Tick" }
            ],
            "transitions": [
              { "from": "calm", "to": "calm", "event": "INIT" },
              { "from": "calm", "to": "enraged", "event": "TAKE_DAMAGE", "guard": [">=", "@payload.amount", 10], "effects": [["set", "@entity.attack", ["+", "@entity.attack", 5]], ["persist", "update", "Unit", "@entity"]] },
              { "from": "enraged", "to": "enraged", "event": "ATTACK", "effects": [["set", "@entity.damageBonus", 1.5], ["persist", "update", "Unit", "@entity"], ["render-ui", "overlay", { "type": "canvas-effect", "actionType": "melee", "x": "@entity.positionX", "y": "@entity.positionY", "intensity": 1.5 }]] },
              { "from": "enraged", "to": "exhausted", "event": "TICK", "guard": [">=", "@entity.turnsEnraged", 3] },
              { "from": "exhausted", "to": "calm", "event": "REST" },
              { "from": "exhausted", "to": "calm", "event": "TICK", "guard": [">=", "@entity.restTurns", 2] }
            ]
          }
        },
        {
          "name": "SpellweaverBehavior",
          "category": "lifecycle",
          "linkedEntity": "Unit",
          "stateMachine": {
            "states": [
              { "name": "channeling", "isInitial": true },
              { "name": "casting" },
              { "name": "recovering" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "CHANNEL", "name": "Channel" },
              { "key": "CAST_SPELL", "name": "Cast Spell" },
              { "key": "SPELL_COMPLETE", "name": "Spell Complete" },
              { "key": "TICK", "name": "Tick" }
            ],
            "transitions": [
              { "from": "channeling", "to": "channeling", "event": "INIT" },
              { "from": "channeling", "to": "casting", "event": "CAST_SPELL", "guard": [">=", "@entity.mana", 20], "effects": [["set", "@entity.mana", ["-", "@entity.mana", 20]], ["persist", "update", "Unit", "@entity"], ["render-ui", "overlay", { "type": "canvas-effect", "actionType": "magic", "x": "@entity.positionX", "y": "@entity.positionY" }]] },
              { "from": "casting", "to": "recovering", "event": "SPELL_COMPLETE" },
              { "from": "recovering", "to": "channeling", "event": "TICK", "guard": [">=", "@entity.recoveryTurns", 2] },
              { "from": "channeling", "to": "channeling", "event": "CHANNEL", "effects": [["set", "@entity.mana", ["+", "@entity.mana", 10]], ["persist", "update", "Unit", "@entity"]] }
            ]
          }
        },
        {
          "name": "GuardianBehavior",
          "category": "lifecycle",
          "linkedEntity": "Unit",
          "emits": [
            { "event": "SHIELD_BREAK", "scope": "external", "payload": [{ "name": "unitId", "type": "string", "required": true, "description": "The ID of the unit whose shield was broken" }] }
          ],
          "stateMachine": {
            "states": [
              { "name": "defending", "isInitial": true },
              { "name": "shielding" },
              { "name": "recovering" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "SHIELD_ALLY", "name": "Shield Ally", "payload": [{ "name": "allyId", "type": "string", "required": true }] },
              { "key": "TAKE_DAMAGE", "name": "Take Damage" },
              { "key": "SHIELD_BREAK", "name": "Shield Break" },
              { "key": "TICK", "name": "Tick" }
            ],
            "transitions": [
              { "from": "defending", "to": "defending", "event": "INIT" },
              { "from": "defending", "to": "shielding", "event": "SHIELD_ALLY", "effects": [["set", "@entity.shieldTarget", "@payload.allyId"], ["persist", "update", "Unit", "@entity"], ["render-ui", "overlay", { "type": "canvas-effect", "actionType": "shield", "x": "@entity.positionX", "y": "@entity.positionY" }]] },
              { "from": "shielding", "to": "shielding", "event": "TAKE_DAMAGE", "guard": ["<", "@entity.shieldIntegrity", 0], "effects": [["emit", "SHIELD_BREAK"], ["persist", "update", "Unit", "@entity"]] },
              { "from": "shielding", "to": "recovering", "event": "SHIELD_BREAK" },
              { "from": "recovering", "to": "defending", "event": "TICK", "guard": [">=", "@entity.recoveryTurns", 1] }
            ]
          }
        },
        {
          "name": "TrustBehavior",
          "category": "lifecycle",
          "linkedEntity": "Unit",
          "stateMachine": {
            "states": [
              { "name": "idle", "isInitial": true },
              { "name": "believing" },
              { "name": "inspiring" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "HOPE", "name": "Hope" },
              { "key": "SHINE", "name": "Shine" },
              { "key": "RESET", "name": "Reset" }
            ],
            "transitions": [
              { "from": "idle", "to": "idle", "event": "INIT" },
              { "from": "idle", "to": "believing", "event": "HOPE" },
              { "from": "believing", "to": "inspiring", "event": "SHINE" },
              { "from": "inspiring", "to": "idle", "event": "RESET" }
            ]
          }
        },
        {
          "name": "EndureBehavior",
          "category": "lifecycle",
          "linkedEntity": "Unit",
          "stateMachine": {
            "states": [
              { "name": "idle", "isInitial": true },
              { "name": "scavenging" },
              { "name": "adapting" },
              { "name": "surviving" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "FIND_SCRAP", "name": "Find Scrap" },
              { "key": "INTEGRATE", "name": "Integrate" },
              { "key": "WITHSTAND", "name": "Withstand" },
              { "key": "REST", "name": "Rest" }
            ],
            "transitions": [
              { "from": "idle", "to": "idle", "event": "INIT" },
              { "from": "idle", "to": "scavenging", "event": "FIND_SCRAP" },
              { "from": "scavenging", "to": "adapting", "event": "INTEGRATE" },
              { "from": "adapting", "to": "surviving", "event": "WITHSTAND" },
              { "from": "surviving", "to": "idle", "event": "REST" }
            ]
          }
        },
        {
          "name": "MendBehavior",
          "category": "lifecycle",
          "linkedEntity": "Unit",
          "stateMachine": {
            "states": [
              { "name": "idle", "isInitial": true },
              { "name": "scanning" },
              { "name": "diagnosing" },
              { "name": "healing" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "START_SCAN", "name": "Start Scan" },
              { "key": "DIAGNOSE", "name": "Diagnose" },
              { "key": "ACTIVATE_HEAL", "name": "Activate Heal" },
              { "key": "COMPLETE", "name": "Complete" }
            ],
            "transitions": [
              { "from": "idle", "to": "idle", "event": "INIT" },
              { "from": "idle", "to": "scanning", "event": "START_SCAN" },
              { "from": "scanning", "to": "diagnosing", "event": "DIAGNOSE" },
              { "from": "diagnosing", "to": "healing", "event": "ACTIVATE_HEAL", "effects": [["render-ui", "overlay", { "type": "canvas-effect", "actionType": "heal", "x": "@entity.positionX", "y": "@entity.positionY" }]] },
              { "from": "healing", "to": "idle", "event": "COMPLETE" }
            ]
          }
        },
        {
          "name": "DefendBehavior",
          "category": "lifecycle",
          "linkedEntity": "Unit",
          "stateMachine": {
            "states": [
              { "name": "idle", "isInitial": true },
              { "name": "shielding" },
              { "name": "countering" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "SUMMON_SHIELD", "name": "Summon Shield" },
              { "key": "ABSORB_IMPACT", "name": "Absorb Impact" },
              { "key": "LOWER_SHIELD", "name": "Lower Shield" }
            ],
            "transitions": [
              { "from": "idle", "to": "idle", "event": "INIT" },
              { "from": "idle", "to": "shielding", "event": "SUMMON_SHIELD" },
              { "from": "shielding", "to": "countering", "event": "ABSORB_IMPACT", "effects": [["render-ui", "overlay", { "type": "canvas-effect", "actionType": "shield", "x": "@entity.positionX", "y": "@entity.positionY" }]] },
              { "from": "countering", "to": "idle", "event": "LOWER_SHIELD" }
            ]
          }
        },
        {
          "name": "DisruptBehavior",
          "category": "lifecycle",
          "linkedEntity": "Unit",
          "stateMachine": {
            "states": [
              { "name": "idle", "isInitial": true },
              { "name": "infiltrating" },
              { "name": "overloading" },
              { "name": "breaking" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "CONNECT", "name": "Connect" },
              { "key": "INJECT", "name": "Inject" },
              { "key": "SHATTER", "name": "Shatter" },
              { "key": "DISCONNECT", "name": "Disconnect" }
            ],
            "transitions": [
              { "from": "idle", "to": "idle", "event": "INIT" },
              { "from": "idle", "to": "infiltrating", "event": "CONNECT" },
              { "from": "infiltrating", "to": "overloading", "event": "INJECT" },
              { "from": "overloading", "to": "breaking", "event": "SHATTER", "effects": [["render-ui", "overlay", { "type": "canvas-effect", "actionType": "debuff", "x": "@entity.positionX", "y": "@entity.positionY", "intensity": 2 }]] },
              { "from": "breaking", "to": "idle", "event": "DISCONNECT" }
            ]
          }
        },
        {
          "name": "CommandBehavior",
          "category": "lifecycle",
          "linkedEntity": "Unit",
          "stateMachine": {
            "states": [
              { "name": "idle", "isInitial": true },
              { "name": "assessing" },
              { "name": "directing" },
              { "name": "coordinating" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "TACTICAL_VIEW", "name": "Tactical View" },
              { "key": "ISSUE_ORDER", "name": "Issue Order" },
              { "key": "SYNC_SQUAD", "name": "Sync Squad" },
              { "key": "STAND_DOWN", "name": "Stand Down" }
            ],
            "transitions": [
              { "from": "idle", "to": "idle", "event": "INIT" },
              { "from": "idle", "to": "assessing", "event": "TACTICAL_VIEW" },
              { "from": "assessing", "to": "directing", "event": "ISSUE_ORDER" },
              { "from": "directing", "to": "coordinating", "event": "SYNC_SQUAD", "effects": [["render-ui", "overlay", { "type": "canvas-effect", "actionType": "buff", "x": "@entity.positionX", "y": "@entity.positionY" }]] },
              { "from": "coordinating", "to": "idle", "event": "STAND_DOWN" }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "BattlefieldPage",
          "path": "/battle/:enemyId",
          "viewType": "list",
          "primaryEntity": "Unit",
          "isInitial": true,
          "traits": [
            { "ref": "BattlePhaseController" },
            { "ref": "BerserkerBehavior" },
            { "ref": "SpellweaverBehavior" },
            { "ref": "GuardianBehavior" },
            { "ref": "TrustBehavior" },
            { "ref": "EndureBehavior" },
            { "ref": "MendBehavior" },
            { "ref": "DefendBehavior" },
            { "ref": "DisruptBehavior" },
            { "ref": "CommandBehavior" }
          ]
        }
      ],
      "domainContext": {
        "category": "game",
        "vocabulary": {
          "item": "Unit",
          "create": "Spawn Unit",
          "delete": "Defeat Unit",
          "view": "Select Unit"
        },
        "requestFragment": "Canvas-based isometric tactical combat with trait-driven unit behaviors, combat log, and real-time trait state visualization"
      }
    },
    {
      "name": "StrategicCastle",
      "description": "Canvas-based castle management with isometric courtyard, buildings, garrison, and recruitment",
      "visual_prompt": "Scene: Isometric castle courtyard with buildings and garrison. Style: 'Illuminated Manuscript Futurism'. Layout: Stone courtyard with walls, towers, and functional buildings. Atmosphere: Medieval stronghold management.",
      "entity": {
        "name": "Building",
        "persistence": "persistent",
        "collection": "buildings",
        "fields": [
          { "name": "id", "type": "string", "required": true, "primaryKey": true },
          { "name": "name", "type": "string", "required": true },
          { "name": "buildingType", "type": "enum", "values": ["townHall", "barracks", "stable", "workshop", "market", "temple", "tower", "wall"], "required": true },
          { "name": "level", "type": "number", "required": true },
          { "name": "maxLevel", "type": "number", "default": 5 },
          { "name": "positionX", "type": "number", "required": true },
          { "name": "positionY", "type": "number", "required": true },
          { "name": "isConstructing", "type": "boolean", "default": false },
          { "name": "turnsRemaining", "type": "number", "default": 0 },
          { "name": "goldCost", "type": "number", "default": 0 },
          { "name": "resonanceCost", "type": "number", "default": 0 },
          { "name": "ownerId", "type": "string" },
          { "name": "sessionId", "type": "string" }
        ],
        "instances": [
          { "id": "barracks-1", "name": "Barracks", "buildingType": "barracks", "level": 1, "maxLevel": 5, "positionX": 2, "positionY": 1, "goldCost": 200, "resonanceCost": 0 },
          { "id": "library-1", "name": "Arcane Library", "buildingType": "temple", "level": 1, "maxLevel": 5, "positionX": 4, "positionY": 1, "goldCost": 350, "resonanceCost": 50 },
          { "id": "forge-1", "name": "Forge", "buildingType": "workshop", "level": 1, "maxLevel": 5, "positionX": 2, "positionY": 4, "goldCost": 300, "resonanceCost": 0 },
          { "id": "market-1", "name": "Marketplace", "buildingType": "market", "level": 1, "maxLevel": 5, "positionX": 4, "positionY": 4, "goldCost": 150, "resonanceCost": 0 },
          { "id": "portal-1", "name": "Resonance Portal", "buildingType": "tower", "level": 1, "maxLevel": 3, "positionX": 3, "positionY": 6, "goldCost": 500, "resonanceCost": 100 }
        ]
      },
      "traits": [
        {
          "name": "CastleManagement",
          "category": "interaction",
          "linkedEntity": "Building",
          "listens": [
            { "event": "TURN_CHANGED", "from": "SessionManager" }
          ],
          "emits": [
            { "event": "SPEND_GOLD", "scope": "external", "payload": [{ "name": "amount", "type": "number", "required": true }, { "name": "reason", "type": "string", "required": true }] }
          ],
          "stateMachine": {
            "states": [
              { "name": "overview", "isInitial": true },
              { "name": "buildingDetail" },
              { "name": "recruiting" },
              { "name": "upgrading" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "SELECT_BUILDING", "name": "Select Building", "payload": [{ "name": "buildingId", "type": "string", "required": true }, { "name": "buildingName", "type": "string" }, { "name": "buildingType", "type": "string" }, { "name": "level", "type": "number" }] },
              { "key": "OPEN_RECRUIT", "name": "Open Recruitment", "payload": [{ "name": "unitId", "type": "string" }, { "name": "unitName", "type": "string" }, { "name": "unitType", "type": "string" }, { "name": "attack", "type": "number" }, { "name": "defense", "type": "number" }, { "name": "health", "type": "number" }, { "name": "goldCost", "type": "number" }, { "name": "available", "type": "number" }] },
              { "key": "RECRUIT_UNIT", "name": "Recruit Unit", "payload": [{ "name": "goldCost", "type": "number", "required": true }] },
              { "key": "UPGRADE_BUILDING", "name": "Upgrade Building" },
              { "key": "BACK", "name": "Back to Overview" },
              { "key": "EXIT_CASTLE", "name": "Exit Castle" },
              { "key": "TURN_CHANGED", "name": "Turn Changed", "payload": [{ "name": "activePlayerId", "type": "string", "required": true }, { "name": "turn", "type": "number", "required": true }] }
            ],
            "transitions": [
              {
                "from": "overview",
                "to": "overview",
                "event": "INIT",
                "effects": [
                  ["fetch", "Building", { "ownerId": "@user.id" }],
                  ["render-ui", "main", {
                    "type": "game-isometric-canvas",
                    "entity": "@entity",
                    "scale": 0.6,
                    "onTileClick": "SELECT_BUILDING"
                  }],
                  ["render-ui", "hud-top", {
                    "type": "game-resource-bar",
                    "resources": ["gold", "resonance", "salvage"],
                    "compact": false
                  }]
                ]
              },
              {
                "from": "overview",
                "to": "buildingDetail",
                "event": "SELECT_BUILDING",
                "effects": [
                  ["render-ui", "sidebar", {
                    "type": "game-building-slot",
                    "buildingType": "@payload.buildingType",
                    "name": "@payload.buildingName",
                    "level": "@payload.level",
                    "maxLevel": 5,
                    "isSelected": true,
                    "onClick": "UPGRADE_BUILDING"
                  }]
                ]
              },
              {
                "from": "buildingDetail",
                "to": "recruiting",
                "event": "OPEN_RECRUIT",
                "effects": [
                  ["render-ui", "sidebar", {
                    "type": "game-recruit-card",
                    "id": "@payload.unitId",
                    "name": "@payload.unitName",
                    "unitType": "@payload.unitType",
                    "tier": 1,
                    "attack": "@payload.attack",
                    "defense": "@payload.defense",
                    "health": "@payload.health",
                    "goldCost": "@payload.goldCost",
                    "available": "@payload.available",
                    "onRecruit": "RECRUIT_UNIT"
                  }]
                ]
              },
              {
                "from": "recruiting",
                "to": "overview",
                "event": "RECRUIT_UNIT",
                "effects": [
                  ["emit", "SPEND_GOLD", { "amount": "@payload.goldCost", "reason": "recruitment" }],
                  ["persist", "create", "Unit", "@payload"]
                ]
              },
              {
                "from": "buildingDetail",
                "to": "upgrading",
                "event": "UPGRADE_BUILDING",
                "effects": [
                  ["emit", "SPEND_GOLD", { "amount": "@entity.goldCost", "reason": "upgrade" }],
                  ["set", "@entity.level", ["+", "@entity.level", 1]],
                  ["persist", "update", "Building", "@entity"]
                ]
              },
              {
                "from": "upgrading",
                "to": "overview",
                "event": "BACK"
              },
              {
                "from": "buildingDetail",
                "to": "overview",
                "event": "BACK"
              },
              {
                "from": "overview",
                "to": "overview",
                "event": "EXIT_CASTLE",
                "effects": [
                  ["navigate", "/world"]
                ]
              },
              {
                "from": "overview",
                "to": "overview",
                "event": "TURN_CHANGED",
                "effects": [
                  ["fetch", "Building", { "ownerId": "@user.id" }]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "CastlePage",
          "path": "/castle/:id",
          "viewType": "detail",
          "primaryEntity": "Building",
          "traits": [{ "ref": "CastleManagement" }]
        }
      ],
      "domainContext": {
        "category": "game",
        "vocabulary": {
          "item": "Building",
          "create": "Construct Building",
          "view": "Inspect Building"
        },
        "requestFragment": "Canvas isometric castle courtyard with building management, unit recruitment, and resource tracking"
      }
    },
