        "category": "game",
        "vocabulary": {
          "item": "Hex",
          "create": "Reveal Hex",
          "view": "Explore Hex"
        },
        "requestFragment": "Canvas isometric world map with hero movement, resource collection, castle entry, and battle encounters"
      }
