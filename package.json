{
  "name": "@almadar/runtime",
  "version": "2.1.2",
  "description": "Interpreted runtime for Almadar orbital applications (OrbitalServerRuntime)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./OrbitalServerRuntime": {
      "types": "./dist/OrbitalServerRuntime.d.ts",
      "import": "./dist/OrbitalServerRuntime.js",
      "require": "./dist/OrbitalServerRuntime.js"
    },
    "./ServerBridge": {
      "types": "./dist/ServerBridge.d.ts",
      "import": "./dist/ServerBridge.js",
      "require": "./dist/ServerBridge.js"
    },
    "./createOsHandlers": {
      "types": "./dist/createOsHandlers.d.ts",
      "import": "./dist/createOsHandlers.js",
      "require": "./dist/createOsHandlers.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "prepublishOnly": "pnpm run build",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@almadar/evaluator": ">=2.0.0",
    "@almadar/operators": ">=2.0.0",
    "@almadar/core": ">=2.0.0",
    "@faker-js/faker": "^9.3.0"
  },
  "peerDependencies": {
    "express": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "express": "^4.21.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "eslint": "10.0.0",
    "@typescript-eslint/parser": "8.56.0",
    "@almadar/eslint-plugin": ">=2.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar-runtime.git",
    "directory": "docs/packages/runtime"
  },
  "license": "MIT",
  "keywords": [
    "almadar",
    "runtime",
    "orbital",
    "interpreter"
  ],
  "homepage": "https://github.com/almadar-io/almadar#readme"
}
